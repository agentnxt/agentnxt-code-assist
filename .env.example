# Model name understood by Aider/LiteLLM, for example:
#   gpt-4o
#   openai/gpt-4o
#   anthropic/claude-3-5-sonnet-20241022
AGENTNXT_CODE_ASSIST_MODEL=gpt-4o

# Provider credentials are consumed by Aider/LiteLLM.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional OpenAI-compatible gateway settings.
# OPENAI_API_BASE=https://llm.<your-domain>/v1
# OPENAI_API_KEY=

AGENTNXT_CODE_ASSIST_HOST=127.0.0.1
AGENTNXT_CODE_ASSIST_PORT=8090
AGENTNXT_CODE_ASSIST_AUTO_YES=true
AGENTNXT_CODE_ASSIST_AUTO_COMMITS=false
AGENTNXT_CODE_ASSIST_DRY_RUN=false

# Managed checkout mode.
AGENTNXT_CODE_ASSIST_WORKSPACE=/srv/agennext/code-assist/workspaces
AGENTNXT_CODE_ASSIST_GIT_USER_NAME=agennext-code-assist
AGENTNXT_CODE_ASSIST_GIT_USER_EMAIL=code-assist@agennext.local

# Optional: required for private repos and pushing branches over HTTPS.
# GITHUB_TOKEN=

# Optional Slack notifications. Disabled by default.
AGENTNXT_CODE_ASSIST_ENABLE_SLACK=false
# AGENTNXT_CODE_ASSIST_SLACK_WEBHOOK_URL=

