# Model name understood by Aider/LiteLLM, for example:
#   gpt-4o
#   openai/gpt-4o
#   anthropic/claude-3-5-sonnet-20241022
AGENNEXT_CODE_ASSIST_MODEL=gpt-4o

# Provider credentials are consumed by Aider/LiteLLM.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional OpenAI-compatible gateway settings.
# OPENAI_API_BASE=https://llm.<your-domain>/v1
# OPENAI_API_KEY=

AGENNEXT_CODE_ASSIST_HOST=127.0.0.1
AGENNEXT_CODE_ASSIST_PORT=8090
AGENNEXT_CODE_ASSIST_WEB_PORT=3000
AGENNEXT_CODE_ASSIST_AUTO_YES=true
AGENNEXT_CODE_ASSIST_AUTO_COMMITS=false
AGENNEXT_CODE_ASSIST_DRY_RUN=false

# Managed checkout mode.
AGENNEXT_CODE_ASSIST_WORKSPACE=/srv/agennext/code-assist/workspaces
AGENNEXT_CODE_ASSIST_GIT_USER_NAME=agennext-code-assist
AGENNEXT_CODE_ASSIST_GIT_USER_EMAIL=code-assist@agennext.local

# Optional: required for private repos and pushing branches over HTTPS.
# GITHUB_TOKEN=

# Optional Slack notifications. Disabled by default.
AGENNEXT_CODE_ASSIST_ENABLE_SLACK=false
# AGENNEXT_CODE_ASSIST_SLACK_WEBHOOK_URL=

# Optional generic JSON webhook notifications. Disabled by default.
AGENNEXT_CODE_ASSIST_ENABLE_WEBHOOK=false
# AGENNEXT_CODE_ASSIST_WEBHOOK_URL=https://example.com/agennext-code-assist/webhook

# Optional SMTP email notifications. Disabled by default.
AGENNEXT_CODE_ASSIST_ENABLE_SMTP=false
# AGENNEXT_CODE_ASSIST_SMTP_URL=smtp://user:password@smtp.example.com:587?starttls=true
AGENNEXT_CODE_ASSIST_SMTP_FROM_EMAIL=agennext-code-assist@localhost
# AGENNEXT_CODE_ASSIST_SMTP_TO_EMAIL=ops@example.com

# Optional Caddy edge / automatic HTTPS.
AGENNEXT_CODE_ASSIST_DOMAIN=localhost
AGENNEXT_CODE_ASSIST_API_DOMAIN=api.localhost
CADDY_ACME_EMAIL=admin@example.com

# Optional observability / uptime / secrets stack.
UPTIME_KUMA_PORT=3001
HEALTHCHECKS_PORT=8000
GLITCHTIP_PORT=8081
SIGNOZ_PORT=3301
SIGNOZ_OTLP_GRPC_PORT=4317
SIGNOZ_OTLP_HTTP_PORT=4318
INFISICAL_PORT=8082

# Optional integrations consumed by the app/runtime.
# GLITCHTIP_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agennext-code-assist
# HEALTHCHECKS_PING_URL=

# Secrets below are examples only. Replace before running public services.
HEALTHCHECKS_SECRET_KEY=change-me-healthchecks-secret
GLITCHTIP_POSTGRES_DB=glitchtip
GLITCHTIP_POSTGRES_USER=glitchtip
GLITCHTIP_POSTGRES_PASSWORD=change-me-glitchtip-db-password
GLITCHTIP_SECRET_KEY=change-me-glitchtip-secret
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_DEFAULT_FROM_EMAIL=glitchtip@localhost
GLITCHTIP_DOMAIN=http://localhost:8081
GLITCHTIP_ENABLE_USER_REGISTRATION=true
INFISICAL_POSTGRES_DB=infisical
INFISICAL_POSTGRES_USER=infisical
INFISICAL_POSTGRES_PASSWORD=change-me-infisical-db-password
INFISICAL_ENCRYPTION_KEY=change-me-32-byte-encryption-key
INFISICAL_AUTH_SECRET=change-me-infisical-auth-secret
INFISICAL_SITE_URL=http://localhost:8082

# Legacy AGENTNXT_CODE_ASSIST_* variables are still accepted as compatibility fallbacks.
