{
  email {$CADDY_ACME_EMAIL}
  auto_https on
}

{$AGENNEXT_CODE_ASSIST_DOMAIN:localhost} {
  encode zstd gzip

  @api path /assist /healthz /config /static/*
  reverse_proxy @api agennext-code-assist:8090

  handle /codeassist/* {
    root * /srv/agennext/code-assist/site
    file_server
  }

  reverse_proxy agennext-code-assist-web:3000
}

{$AGENNEXT_CODE_ASSIST_API_DOMAIN:api.localhost} {
  encode zstd gzip
  reverse_proxy agennext-code-assist:8090
}
